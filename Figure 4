Idents(NK_LAB) <- "Response"
deg_results <- FindMarkers(
  object = NK_LAB,
  ident.1 = "Responder",
  ident.2 = "NonResponder",
  test.use = "wilcox",     # Wilcoxon test (default)
  logfc.threshold = 0,     # keep all genes, not only strong ones
  min.pct = 0.1,           # only test genes expressed in ≥10% of cells
  only.pos = FALSE          # include both up and down
)
write.csv(deg_results, "DEG_NK_LAB_RvsNR_DESeq2.csv", row.names = T)



