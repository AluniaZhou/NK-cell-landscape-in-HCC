library(dplyr)
library(fgsea)
library(ggplot2)
rank_tbl <- deg_results %>%
  rownames_to_column("gene") %>%
  filter(!is.na(avg_log2FC), !is.na(p_val))
geneList <- with(rank_tbl, sign(avg_log2FC) * -log10(p_val + 1e-300))
names(geneList) <- rank_tbl$gene
geneList <- geneList[!is.na(geneList)]
geneList <- geneList[!duplicated(names(geneList))]
geneList <- sort(geneList, decreasing = TRUE)
nk3_in_universe <- intersect(NK3_GENES, names(geneList))
term2gene <- data.frame(term = "NK3", gene = nk3_in_universe, check.names = FALSE)
set.seed(123)
gsea_res <- GSEA(
  geneList    = geneList,
  TERM2GENE   = term2gene,
  minGSSize   = 1,
  maxGSSize   = 5000,
  pvalueCutoff= 1,
  verbose     = FALSE,
  seed        = TRUE
)
p <- gseaplot2(
  gsea_res,
  geneSetID     = "NK3",
  title         = "NK3 enrichment (ident.1 vs ident.2)",
  subplots      = c(1,2,3),
  pvalue_table  = TRUE,        # shows NES, p.adjust, etc.
  ES_geom       = "line",
  rel_heights   = c(1.1, 0.3, 0.7)
) 
print(p)
