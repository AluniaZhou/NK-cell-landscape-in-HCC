#1.1 Load YO40245 data
setwd('V:/Analysis Ready Datasets')
library(dplyr)
library(haven)
adrs <- read_sas('adrs.sas7bdat')

#Filter for SD patients
SD_patients <- adrs%>% 
  filter(PARAMCD == 'CBORDF', RSSTRESC %in% c('SD','NON-CR/NON-PD'))%>% 
  pull(UNI_ID) %>% 
  unique()

#Subset SD patients with HOVRF assessment 
adrs_SD <- adrs %>% 
  filter(UNI_ID %in% SD_patients, 
         PARAMCD == 'HOVRF', 
         VISIT %in% c('TUMOR ASSESSMENT WEEK 6','TUMOR ASSESSMENT WEEK 12','TUMOR ASSESSMENT WEEK 18', 'TUMOR ASSESSMENT WEEK 24'))

#Classify response in SD patients
SD_response_class <- adrs_SD %>%
  group_by(UNI_ID) %>%
  summarise(
    responder = case_when(
      any(RSSTRESC == 'PD')~0,
      any(VISIT == 'TUMOR ASSESSMENT WEEK 24' & RSSTRESC %in% c('SD','PR','NON-CR/NON-PD'))~1,
      TRUE ~ NA_real_
    )
  ) %>%
  filter(!is.na(responder))

#Full BR for SD patients with response information
BR_SD <- adrs %>% 
  filter(PARAMCD == 'CBORDF', RSSTRESC %in% c('SD','NON-CR/NON-PD')) %>%
  semi_join(SD_response_class, by = 'UNI_ID') %>%
  left_join(SD_response_class, by = 'UNI_ID')

#Full BR for other patients with response information
BR_CRPRPD <- adrs %>% 
  filter(PARAMCD == 'CBORDF', RSSTRESC %in% c('CR','PR','PD')) %>%
  mutate(responder = ifelse(RSSTRESC %in% c('CR','PR'),1,0))

#Combine all patients with response label
response_combined <- bind_rows(BR_SD,BR_CRPRPD)
  
#1.2 Load YO40245 Survival information
adtte <-read_sas('adtte.sas7bdat')
#Extract OS information
OS_data <- adtte %>%
  filter(PARAMCD == 'OS') %>%
  transmute(
    UNI_ID,
    OS = AVAL,
    OS_Censor = CNSR,
    OS_event = EVNTDESC
  )
#Extract PFS information
PFS_data <- adtte %>%
  filter(PARAMCD == 'PFS') %>%
  transmute(
    UNI_ID,
    PFS = AVAL,
    PFS_Censor = CNSR,
    PFS_event = EVNTDESC
  )
#Merge response table with OS/PFS
DF <- merge(x=response_combined, y=c(OS_data, PFS_data), all.x = T)
DF_response <- dplyr::select(DF, UNI_ID, TRT01P, responder, STUDYID, AGE,
                        SEX, RACE, AFP, AFPC, MVI_EHS2, RSORRES, AVALC, 
                     OS, OS_Censor, OS_event,PFS, PFS_Censor, PFS_event)
  
  
#To include patients with NE response, mark as NA
Pt_NE <- setdiff(unique(adrs$UNI_ID),unique(DF$UNI_ID))
a <- adrs%>% filter(PARAMCD %in% 'CBOR')
NE <- a %>%
  filter(UNI_ID %in% Pt_NE) %>%
