# 4.5 Basic survival plot example
library(survival)
library(survminer)
merged_df_clean$Angio_Group <- ifelse(
  merged_df_clean$Angiogenesis_Score > median(merged_df_clean$Angiogenesis_Score, na.rm = TRUE),
  'High','Low')
surv_obj <- Surv(merged_df_clean$OS, merged_df_clean$OS_event == 'Death')
fit <- survfit(surv_obj ~ Angio_Group, data = merged_df_clean)

# Calculate median survival, p value and HR
medians <- surv_median(fit)
cox_fit <- coxph(surv_obj ~ Angio_Group, data = merged_df_clean)
summary_fit <- summary(cox_fit)
hr <- round(summary_fit$coefficients[1, 'exp(coef)'],2)
ci <- round(summary_fit$conf.int[1, c('lower .95', 'upper .95')],2)
hr_label <- paste0('HR =' , hr, '[', ci[1], '-', ci[2], ']')
pval <- signif(summary_fit$coefficients[1, 'Pr(>|z|)'],3)
pval_label <- paste0('p = ', pval)

P1 <- ggsurvplot(fit, data = merged_df_clean,
           surv.median.line = 'hv',
           risk.table = TRUE,
           risk.table.y.text.col = TRUE,
           risk.table.height = 0.25,
           risk.table.y.text = FALSE,
           break.time.by = 5,
           legend = 'right',
           legend.title = 'Group',
           pval = FALSE,
           palette = c('#E69F00', '#56B4E9'),
           ggtheme = theme_classic2())

P1$table <- P1$table +
  theme(
    axis.title.x = element_blank(),
    axis.text.x = element_blank(),
    axis.ticks.x = element_blank(),
    panel.border = element_blank()
  )

P1$plot <- P1$plot +  annotate('text',
           x= medians$median + 0.5,
           y = 0.02,
           label = paste0(round(medians$median, 1)),
           color = c('#E69F00', '#56B4E9'),
           hjust =0,
           size = 4) +
  annotate('text', x = max(merged_df_clean$OS) * 0.65, y=0.95,
           label = hr_label, hjust = 0, size = 4) +
  annotate('text', x = max(merged_df_clean$OS) * 0.65, y=0.89,
           label = pval_label, hjust = 0, size = 4) +
  annotate('segment', x=0, xend =10, y=0.5, yend =0.5,
           color = 'gray50', linetype = 'dotted')+
  labs(x = 'Time to event (months)', y = 'OS Probability')

