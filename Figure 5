hr <- round(summary_fit$coefficients[1, 'exp(coef)'],2)
ci <- round(summary_fit$conf.int[1, c('lower .95', 'upper .95')],2)
hr_label <- paste0('HR =' , hr, '[', ci[1], '-', ci[2], ']')
pval <- signif(summary_fit$coefficients[1, 'Pr(>|z|)'],3)
pval_label <- paste0('p = ', pval)

