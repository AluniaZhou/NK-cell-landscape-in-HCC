surv_obj <- with(km_df2, Surv(time, status))
cox_one_gene <- function(gene_expr) {
  fit <- tryCatch(
    coxph(surv_obj ~ as.numeric(gene_expr)),
    error = function(e) NULL
  )
  if (is.null(fit)) return(c(beta = NA, p = NA))
  s <- summary(fit)
  c(beta = s$coefficients[1, "coef"],
    p = s$coefficients[1, "Pr(>|z|)"])
}
