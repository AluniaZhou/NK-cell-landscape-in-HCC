smooth_gene <- function(y, x, xout, df = 3) {
  dat <- data.frame(y = as.numeric(y), x = as.numeric(x))
  dat <- dat[is.finite(dat$y) & is.finite(dat$x), , drop = FALSE]
  
  if (nrow(dat) < 10 || sd(dat$y, na.rm = TRUE) == 0) {
    return(rep(0, length(xout)))
  }
  fit <- tryCatch(
    lm(y ~ splines::ns(x, df = df), data = dat),
    error = function(e) NULL
  )
  
  if (is.null(fit)) {
    return(rep(0, length(xout)))
  }
  pred <- tryCatch(
    predict(fit, newdata = data.frame(x = xout)),
    error = function(e) rep(0, length(xout))
  )
  
  as.numeric(pred)
}
smooth_mat <- t(apply(expr_mat, 1, smooth_gene, x = pt_sorted, xout = pt_grid, df = 3))
