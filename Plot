#Plot 2I Cell proportion correlation
Base <- subset(CD45, subset = Timing == 'Baseline')
BaseHCC <- subset(Base, subset = Tissue == 'HCC')
## ---- SETTINGS ----
obj           <- BaseHCC                 # Seurat object
sample_col    <- "Patient_ID"
cell_col      <- "CelltypeL2"
x_ct          <- "NK_CD56"           # X-axis / reference cell type
min_cells_ct  <- 50                     # minimum cells per (patient, cell type)
method        <- "spearman"              # or "pearson"
pt_color      <- "#E06A42"               # tweak as you like
suppressPackageStartupMessages({
  library(dplyr); library(tidyr); library(ggplot2); library(ggpubr); library(purrr)
})
## ---- 0) Clean meta ----
meta_df <- obj@meta.data[, c(sample_col, cell_col), drop = FALSE] %>%
  mutate(
    sample_id = trimws(as.character(.data[[sample_col]])),
    celltype  = trimws(as.character(.data[[cell_col]]))
  ) %>%
  select(sample_id, celltype)
## ---- 1) Counts per (patient, celltype) + patient totals ----
ct_counts <- meta_df %>%
  count(sample_id, celltype, name = "n_cells")
patient_totals <- ct_counts %>%
  group_by(sample_id) %>%
  summarise(n_total = sum(n_cells), .groups = "drop")
## ---- 2) Keep only (patient, celltype) with enough cells ----
ct_counts_filt <- ct_counts %>%
  filter(n_cells >= min_cells_ct)
## ---- 3) Build proportion table (rowwise by patient) from filtered pairs ----
# First, merge back totals (based on all cells so proportions sum to 1 only if all CTs pass the threshold;
# that's OK because we care about *pairwise* correlations, not compositional closure.)
prop_tab <- ct_counts_filt %>%
  left_join(patient_totals, by = "sample_id") %>%
  mutate(prop = n_cells / n_total) %>%
  select(sample_id, celltype, prop) %>%
  pivot_wider(names_from = celltype, values_from = prop)
## ---- 4) Choose X cell type and list other CTs present after filtering ----
stopifnot(x_ct %in% names(prop_tab))
other_cts <- setdiff(names(prop_tab), c("sample_id", x_ct))
## ---- 5) Helper: build pairwise dataset requiring BOTH CTs present for a patient ----
get_pair_df <- function(y_ct) {
  prop_tab %>%
    select(sample_id, X = all_of(x_ct), Y = all_of(y_ct)) %>%
    drop_na(X, Y)
}
## ---- 6) Pretty scatter like your example ----
plot_pair <- function(y_ct) {
  dat <- get_pair_df(y_ct)
  if (nrow(dat) < 3) return(NULL)  # not enough points to fit a line
  # compute correlation once so we can format the annotation exactly
  ct <- suppressWarnings(cor.test(dat$X, dat$Y, method = method))
  r_lab <- sprintf("R=%.2f", unname(ct$estimate))
  p_lab <- if (ct$p.value < 0.001) "P<0.001" else sprintf("P=%.3f", ct$p.value)
  lab   <- paste0(r_lab, ",", p_lab)
  ggplot(dat, aes(x = X, y = Y)) +
    geom_point(size = 2.6, alpha = 0.9, color = pt_color) +
    geom_smooth(method = "lm", se = TRUE, linewidth = 0.8, color = pt_color, fill = "grey80") +
    annotate("text", x = -Inf, y = Inf, hjust = -0.05, vjust = 1.2,
             label = lab, size = 4.2) +
    labs(
      x = paste0("Proportion of ", x_ct),
      y = paste0("Proportion of ", y_ct)
    ) +
    theme_bw(base_size = 12) +
    theme(
      panel.grid = element_blank(),
      axis.title = element_text(color = "black"),
      axis.text  = element_text(color = "black"),
      plot.title = element_text(hjust = 0, face = "bold"),
      panel.border = element_rect(color = "black", fill = NA, linewidth = 0.6)
    )
}
## ---- 7) Generate plots for all Y CTs that have enough paired patients ----
plots <- map(other_cts, plot_pair)
plots <- plots[!vapply(plots, is.null, logical(1))]
## ---- 8) Save individual pages (like before) ----
pdf(sprintf("scatter_vs_%s.filtered.pdf", gsub("[^A-Za-z0-9]+","_", x_ct)),
    width = 4.2, height = 4.2)
invisible(lapply(plots, print))
dev.off()
message(sprintf("Saved %d pages (patients with >=%d cells in BOTH CTs).",
                length(plots), min_cells_ct))

