d<- subset(d, subset = !is.na(Response))
cell_prop <- d@meta.data %>%
  group_by(Patient_ID, Response, CellType = d$CelltypeL2) %>%
  summarise(n = n()) %>%
  group_by(Patient_ID) %>%
  mutate(prop = n / sum(n)) %>%
  ungroup()
ggplot(cell_prop, aes(x = Response, y = prop)) +
  geom_boxplot(
    aes(color = Response),
    fill = "white",
    outlier.shape = NA,
    linewidth = 0.8
  ) +
  geom_jitter(
    aes(color = Response),
    width = 0.15,
    size = 2,
    alpha = 0.8
  ) +
  facet_wrap(~CellType, scales = "free_y", nrow = 1) +
  scale_color_manual(
    values = c("Responder" = "#E04B4A", "NonResponder" = "#5AAAE3")
  ) +
  scale_y_continuous(limits = c(0, y_max * 1.1)) +
  theme_classic(base_size = 14) +
  theme(
    legend.position = "none",
    axis.text.x = element_text(angle = 30, hjust = 1),
    strip.background = element_blank(),
    strip.text = element_text(face = "bold"),
    panel.spacing = unit(0.8, "lines")
  ) +
  ylab("Proportion of cells") +
  xlab("")

