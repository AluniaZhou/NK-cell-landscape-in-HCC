# sparse row-aggregation helper (no Matrix.utils needed)
.sparse_rowsum_by_group <- function(mat, group_ids) {
  stopifnot(nrow(mat) == length(group_ids))
  f <- factor(group_ids, levels = unique(group_ids))
  G <- Matrix::sparseMatrix(i = seq_along(f), j = as.integer(f), x = 1,
                            dims = c(length(f), nlevels(f)))
  methods::as(Matrix::t(G) %*% mat, "dgCMatrix")
}
# (optional) canonicalize common no-dash MT aliases (protein-coding & rRNA)
.canonize_mt_alias <- function(sym) {
  # map e.g. "MTCO1" -> "MT-CO1", "MTATP6" -> "MT-ATP6", "MTRNR1" -> "MT-RNR1", etc.
  patterns <- c("CO1","CO2","CO3","ND1","ND2","ND3","ND4","ND4L","ND5","ND6",
                "ATP6","ATP8","CYB","RNR1","RNR2")
  for (p in patterns) {
    sym <- sub(paste0("^MT", p, "$"), paste0("MT-", p), sym, ignore.case = FALSE)
  }
  sym
}
# Convert SYMBOL -> Ensembl (keep MT genes by symbol), counts-only, v5-safe
to_ensembl_keepMT <- function(seu, assay = "RNA", keep_unmapped = TRUE, project = NULL) {
  stopifnot(assay %in% names(seu@assays))
  DefaultAssay(seu) <- assay
  # keep counts layer only (avoid layer mismatches)
  seu <- DietSeurat(
    seu,
    assays = assay,
    layers = setNames(list("counts"), assay),
    dimreducs = NULL,
    graphs = NULL
  )
  mat <- GetAssayData(seu, assay = assay, layer = "counts")
  if (!inherits(mat, "dgCMatrix")) mat <- as(mat, "CsparseMatrix")
  syms <- rownames(mat)
  # Canonicalize obvious no-dash MT aliases first
  syms2 <- vapply(syms, .canonize_mt_alias, character(1))
  # Identify MT genes: most official human MT genes start with "MT-"
  is_mt <- grepl("^MT-", syms2)
  # Map non-MT symbols to Ensembl
  ens <- rep(NA_character_, length(syms2))
  if (any(!is_mt)) {
    ens[!is_mt] <- mapIds(org.Hs.eg.db,
                          keys = syms2[!is_mt],
                          keytype = "SYMBOL",
                          column  = "ENSEMBL",
                          multiVals = "first")
  }
  # Build grouping IDs:
  #  - MT genes: keep their (canonicalized) SYMBOL so they persist
  #  - non-MT genes: use Ensembl if available, else UNMAPPED_SYMBOL:<symbol>
  grp <- character(length(syms2))
  grp[is_mt] <- syms2[is_mt]
  grp[!is_mt] <- ens[!is_mt]
  if (keep_unmapped) {
    idx_na <- which(!is_mt & is.na(grp))
    if (length(idx_na)) grp[idx_na] <- paste0("UNMAPPED_SYMBOL:", syms2[idx_na])
  } else {
    keep <- is_mt | (!is.na(grp))
    mat  <- mat[keep, , drop = FALSE]
    grp  <- grp[keep]
    syms2 <- syms2[keep]
  }
  # Aggregate duplicates by target id (Ensembl or MT symbol)
  mat_agg <- .sparse_rowsum_by_group(mat, grp)
  rownames(mat_agg) <- unique(grp)
  seu[[assay]] <- CreateAssayObject(counts = mat_agg)
  if (!is.null(project)) seu@project.name <- project
  # store mapping for audit
  seu@misc$symbol_to_target <- data.frame(
    original_symbol = syms,
    canonical_symbol = syms2,
    target_id = grp,
    is_mt = is_mt,
    stringsAsFactors = FALSE
  )
  seu
}
