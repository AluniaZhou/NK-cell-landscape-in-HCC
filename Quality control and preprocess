meta <- Fib1@meta.data
# 1) Find cells where Patient_ID is missing (treat NA, empty string, or literal "NA" as missing)
na_idx <- is.na(meta$Patient_ID) | meta$Patient_ID == "" | meta$Patient_ID == "NA"
# 2) Inspect which Batch and Sample_ID those NA cells are from
na_overview <- meta[na_idx, c("Batch", "Sample_ID", "Patient_ID")]
# Quick counts by Batch/Sample_ID
na_counts <- as.data.frame(na_overview) |>
  dplyr::count(Batch, Sample_ID, name = "n")
was_factor <- is.factor(Fib1$Patient_ID)
Fib1$Patient_ID <- as.character(Fib1$Patient_ID)
Fib1$Sample_ID  <- as.character(Fib1$Sample_ID)
Fib1$Patient_ID[na_idx] <- Fib1$Sample_ID[na_idx] # Restore factor if it started as factor, and drop unused levels
if (was_factor) {
  Fib1$Patient_ID <- factor(Fib1$Patient_ID)
}
Fib1 <- NormalizeData(Fib1)
Fib1 <- FindVariableFeatures(Fib1)
Fib1 <- ScaleData(Fib1)
Fib1 <- RunPCA(Fib1)
Fib1 <- RunHarmony(Fib1, group.by.vars = "Patient_ID")
Fib1 <- FindNeighbors(Fib1, reduction = "harmony", dims = 1:16)
Fib1 <- FindClusters(Fib1, resolution = 1.2, cluster.name = "harmony_clusters")
Fib1 <- RunUMAP(Fib1,reduction = "harmony", dims = 1:16, reduction.name = "umap.harmony")
DimPlot(Fib1, reduction = 'umap.harmony', label = T)
Fib2 <- subset(Fib1, !(subset = harmony_clusters %in% c('4','7','9','11','12','13','14','15','18','22')))
Fib2 <- NormalizeData(Fib2)
Fib2 <- FindVariableFeatures(Fib2)
Fib2 <- ScaleData(Fib2)
Fib2 <- RunPCA(Fib2)
Fib2 <- RunHarmony(Fib2, group.by.vars = "Patient_ID")
Fib2 <- FindNeighbors(Fib2, reduction = "harmony", dims = 1:15)
Fib2 <- FindClusters(Fib2, resolution = 0.7, cluster.name = "harmony_clusters")
Fib2 <- RunUMAP(Fib2,reduction = "harmony", dims = 1:15, reduction.name = "umap.harmony")
DimPlot(Fib2, reduction = 'umap.harmony', label = T)
NK.markers <- FindAllMarkers(Fib2, only.pos = TRUE)
NK.markers %>%
  group_by(cluster) %>%
  dplyr::filter(avg_log2FC > 1) %>%
  slice_head(n = 10) %>%
  ungroup() -> top10
DoHeatmap(Fib2, features = top10$gene) + NoLegend()
Fib2 <- subset(Fib2, !(subset = harmony_clusters %in% c('1','16','17','18')))
Fib2@meta.data[which(Fib2@meta.data$harmony_clusters %in% c('4','8','9','11','12','14')),'CelltypeL2'] <- 'Fibroblast'
Fib2@meta.data[which(Fib2@meta.data$harmony_clusters %in% c('4','8','9','11','12')),'Celltype3'] <- 'HSC_RBP1'
Fib2@meta.data[which(Fib2@meta.data$harmony_clusters %in% c('14')),'Celltype3'] <- 'Fibroblast_portal_SFRP2'

Fib2@meta.data[which(Fib2@meta.data$harmony_clusters %in% c('0','7','15')),'CelltypeL2'] <- 'Perivascular'
Fib2@meta.data[which(Fib2@meta.data$harmony_clusters %in% c('0','7','15')),'Celltype3'] <- 'Perivascular_CD36'

Fib2@meta.data[which(Fib2@meta.data$harmony_clusters %in% c('2','3','5','6','10','13')),'CelltypeL2'] <- 'Mural'
Fib2@meta.data[which(Fib2@meta.data$harmony_clusters %in% c('2','3','6','13')),'Celltype3'] <- 'Mural_PLN'
Fib2@meta.data[which(Fib2@meta.data$harmony_clusters %in% c('5','10')),'Celltype3'] <- 'Mural_FOS'

NKT <- readRDS('T and NK_Clean.rds')
Myeloid <- readRDS('Myeloid_Clean.rds')
B <- readRDS('B_Clean.rds')
Endo <- readRDS('Endo_Clean.rds')
Fib <- readRDS('Fib_Clean.rds')
Hepa <- readRDS('Hepa.rds')
scRNA<- merge(x=NKT, y=c(Myeloid,B,Endo,Fib,Hepa))
mem.maxVSize(vsize = 300 * 1024)
scRNA <- JoinLayers(scRNA)

scRNA <- NormalizeData(scRNA)
scRNA <- FindVariableFeatures(scRNA)
scRNA <- ScaleData(scRNA)
scRNA <- RunPCA(scRNA)
scRNA <- RunHarmony(scRNA, group.by.vars = "Patient_ID")
ElbowPlot(scRNA)
scRNA <- FindNeighbors(scRNA, reduction = "harmony", dims = 1:15)
scRNA <- FindClusters(scRNA, resolution = 1.2, cluster.name = "harmony_clusters")
scRNA <- RunUMAP(scRNA,reduction = "harmony", dims = 1:15, reduction.name = "umap.harmony")
DimPlot(scRNA, reduction = 'umap.harmony', label = T)
scRNA$Celltype[which(scRNA$Celltype == 'T and NK')] <- 'T'
scRNA$CelltypeL2[which(scRNA$Celltype == 'Hepatocytes')] <- 'Hepatocytes'
scRNA$Celltype3[which(scRNA$Celltype == 'Hepatocytes')] <- 'Hepatocytes'

scRNA <- readRDS('scRNA_Clean.rds')
































