# Loading GSE112271
library(Seurat)
library(Matrix)
library(stringr)
data_dir <- "/Users/alunia/RData/Public HCC/112271/GSE112271_RAW"
mtx_files <- list.files(data_dir, pattern = "_matrix\\.mtx\\.gz$", full.names = TRUE)
read_one_sample <- function(mtx_path) {
  root <- sub("_matrix\\.mtx\\.gz$", "", basename(mtx_path))
  barcodes <- file.path(dirname(mtx_path), paste0(root, "_barcodes.tsv.gz"))
  features1 <- file.path(dirname(mtx_path), paste0(root, "_features.tsv.gz"))  
  features2 <- file.path(dirname(mtx_path), paste0(root, "_genes.tsv.gz"))     
  features <- if (file.exists(features1)) features1 else if (file.exists(features2)) features2 else NA
  if (!file.exists(barcodes)) stop(paste0("Missing barcodes for ", root))
  if (is.na(features)) stop(paste0("Missing features/genes file for ", root))
  mat <- ReadMtx(mtx = mtx_path, features = features, cells = barcodes)
  obj <- CreateSeuratObject(mat, project = root, min.cells = 0, min.features = 0)
  obj$Sample_ID  <- root
  obj$Patient_ID <- sub("\\.[^.]+$", "", root)
  obj$orig.ident <- root
  colnames(obj) <- paste0(root, "_", colnames(obj))
  obj
}
objs <- lapply(mtx_files, read_one_sample)
if (length(objs) == 1) {
  seu <- objs[[1]]
} else {
  seu <- Reduce(function(a, b) merge(a, y = b), objs)
}
gse112271 <- seu
